# Copy this file to .env or .env.local and fill values for EmailJS.
# Use the same template names for both VITE and Create React App setups.

# Vite env names (if you're using Vite)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_GUEST_TEMPLATE_ID=your_guest_template_id
VITE_EMAILJS_HOST_TEMPLATE_ID=your_host_template_id
VITE_HOST_EMAIL=host@stayvista-tagaytay.com

# Create React App env names (if you're using react-scripts)
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
REACT_APP_EMAILJS_GUEST_TEMPLATE_ID=your_guest_template_id
REACT_APP_EMAILJS_HOST_TEMPLATE_ID=your_host_template_id
REACT_APP_HOST_EMAIL=host@stayvista-tagaytay.com
